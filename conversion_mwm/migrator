#!/usr/bin/python3

import configparser
import os
import sys

class migrator:

    def __init__(self, cnf):
        self.psql_sam = cnf.get("psql_commands", "sam_db")
        self.psql_meta = cnf.get("psql_commands", "meta_db")
        os.environ.update(dict(cnf['env']))
        self.ordered_tables = [
            'users',
            'roles',
            'namespaces',
            'files',
            'parent_child',
            'queries',
            'datasets',
            'datasets_parent_child',
            'files_datasets',
        ]

    def schlep_table(self, table, filter = "cat", format=""):

       os.system(f'''
           set -x;
           {self.psql_sam}  -c "copy (select * from meta_{table}) TO stdout {format};" | 
              {filter} |
              {self.psql_meta} -c "set search_path=metacat; copy {table} from stdin {format};" 
       ''')

    def migrate(self):

        # create views in SAM side
        os.system(f"{self.psql_sam} < views.sql")
        os.system(f"{self.psql_meta} < clean_slate.sql")

        # schlep data...
        for table in self.ordered_tables: 

            if table == 'queries':
                self.schlep_table(table, filter='./sam_parser/new_query_converter.py', format='csv')
            else:
                self.schlep_table(table)


if __name__ == '__main__':

    cp = configparser.ConfigParser()

    # don't lowercase config entries, so env variables are right...
    cp.optionxform = lambda option: option

    cp.read("migrator.ini")
    migrator(cp).migrate()

